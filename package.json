{
  "name": "armanvarzesh-monorepo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "lint": "pnpm -r run lint",
    "format": "prettier -w .",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "build": "pnpm -r run build",
    "build:backend": "pnpm --filter ./app/backend run build",
    "build:vitrin": "pnpm --filter ./app/vitrin-site run build",
    "build:user": "pnpm --filter ./app/user-app run build || true",
    "build:coach": "pnpm --filter ./app/coach-app run build || true",
    "test:cov": "pnpm -r test:cov",
    "format:check": "prettier -c .",
    "start": "node dist/main.js || next start -p 3000 || echo \"no start\"",
    "clean": "rimraf dist || true",
    "test:e2e": "echo \"e2e placeholder\"",
    "dev": "nodemon --exec ts-node src/main.ts || echo \"dev script placeholder\"",
    "prepare": "husky install || true",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "env:collect": "node tools/env/collect-env.cjs",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "audit:prod": "pnpm audit --prod",
    "audit:full": "pnpm audit",
    "optimize:assets": "node scripts/optimize-assets.mjs",
    "postinstall": "echo ok",
    "check:repo": "node scripts/verify-clean.mjs",
    "db:init:plan": "echo 'Run per-service migrations/PLAN_stage08/db_init.sh'",
    "test:e2e:flow": "node -e \"console.log('Configure jest with tools/e2e/jest.config.e2e.js')\"",
    "start:prod": "node dist/main.js",
    "check:dups": "node scripts/detect-duplicates.mjs | jq 'keys' && test $(node scripts/detect-duplicates.mjs | jq 'keys | length') -eq 0",
    "check:score": "node scripts/score.mjs > .reports/score.json && cat .reports/score.json | jq 'map(.s) | {min:(min),avg:(add/length),max:(max)}'",
    "smoke": "node scripts/smoke-security.mjs",
    "e2e:backend": "node scripts/e2e-backend.mjs",
    "openapi:validate": "node scripts/validate-openapi.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "publish-packages": "changeset publish",
    "version": "changeset version",
    "coverage:report": "pnpm -r test -- --coverage",
    "coverage": "pnpm -r run coverage",
    "sbom": "pnpm dlx @cyclonedx/cyclonedx-npm --output-file sbom.json",
    "audit": "pnpm audit --audit-level=high || true",
    "secret-scan": "pnpm dlx gitleaks detect --no-git -v || true",
    "typecheck:all": "pnpm -r typecheck",
    "lint:all": "pnpm -r lint",
    "test:all": "pnpm -r test -- --ci",
    "coverage:all": "pnpm -r run coverage",
    "build:all": "pnpm -r build",
    "sbom:all": "npx @cyclonedx/cyclonedx-npm --ignore-npm-errors --json --output-file sbom.json",
    "scan:secrets": "gitleaks detect --no-git -v || true",
    "scan:deps": "pnpm audit --audit-level=high || true",
    "lint:repo": "eslint . --ext .ts,.tsx,.js,.jsx --max-warnings=0",
    "test:repo": "jest --ci --coverage --runInBand",
    "coverage:check": "node scripts/check-coverage.js",
    "perf:smoke": "npx autocannon -d 10 -c 50 http://localhost:3000/health || true",
    "perf:smoke:slow": "npx autocannon -d 20 -c 100 http://localhost:3000/health || true",
    "docs:lint": "node scripts/check-docs.js",
    "ci:lh-user": "lhci collect --config=lighthouserc.base.json --collect.staticDistDir=app/user-pwa/dist && lhci assert --config=lighthouserc.base.json",
    "ci:lh-coach": "lhci collect --config=lighthouserc.base.json --collect.staticDistDir=app/coach-pwa/dist && lhci assert --config=lighthouserc.base.json",
    "ci:lh-user:main": "lhci collect --config=lighthouserc.main.json --collect.staticDistDir=app/user-pwa/dist && lhci assert --config=lighthouserc.main.json",
    "ci:lh-coach:main": "lhci collect --config=lighthouserc.main.json --collect.staticDistDir=app/coach-pwa/dist && lhci assert --config=lighthouserc.main.json",
    "ci:lh-user:pr": "lhci collect --config=lighthouserc.pr.json --collect.staticDistDir=app/user-pwa/dist && lhci assert --config=lighthouserc.pr.json",
    "ci:lh-coach:pr": "lhci collect --config=lighthouserc.pr.json --collect.staticDistDir=app/coach-pwa/dist && lhci assert --config=lighthouserc.pr.json",
    "db:generate:all": "bash -lc 'for d in services/* app/* packages/*; do if [ -f \"$d/prisma/schema.prisma\" ]; then (cd \"$d\" && npx prisma generate); elif [ -f \"$d/src/database/prisma/schema.prisma\" ]; then (cd \"$d\" && npx prisma generate --schema src/database/prisma/schema.prisma); fi; done'",
    "db:migrate:all": "bash -lc 'for d in services/* app/* packages/*; do if [ -f \"$d/prisma/schema.prisma\" ]; then (cd \"$d\" && (npx prisma migrate deploy || npx prisma db push --skip-generate)); fi; done'",
    "db:seed:all": "bash scripts/seed_all.sh",
    "ci:queue:test": "node scripts/redis_queue_test.js",
    "ci:openapi:lint": "bash -lc 'for f in app/backend/openapi.yaml app/backend/openapi.yml app/backend/openapi.json; do [ -f \"$f\" ] && npx spectral lint \"$f\" && exit 0; done; echo \"No OpenAPI schema found\"'",
    "db:generate": "pnpm -s dlx prisma generate || true",
    "db:migrate:dev": "pnpm -s dlx prisma migrate dev || true",
    "db:migrate:deploy": "bash ./tools/db/migrate-all.sh",
    "db:seed": "bash ./tools/db/seed-all.sh",
    "test:backend": "jest -c jest.backend.config.cjs --runInBand --passWithNoTests",
    "start:otel": "node -r ./app/backend/src/otel.js dist/main.js"
  },
