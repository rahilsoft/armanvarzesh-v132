#!/usr/bin/env sh
# Pre-commit: fast repo-hygiene check only (large files, secret-like content).
# Lint, typecheck, and tests are enforced per-package in CI (Unified CI);
# running the whole workspace suite on every commit took minutes, and the
# old `pnpm -w lint --if-present` form forwarded --if-present into eslint
# itself (which rejects it), so no commit could ever pass.
pnpm -w check:repo || exit 1
