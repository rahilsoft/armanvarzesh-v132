generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Notification {
  id         String   @id
  userId     String
  templateKey String
  data       Json
  channels   String[] // push,email,sms
  locale     String   @default("fa")
  tz         String   @default("Europe/Amsterdam")
  sendAt     DateTime
  status     String   @default("scheduled") // scheduled|sending|sent|failed|retrying
  attempts   Int      @default(0)
  lastError  String?
  ics        String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Outbox {
  id        String   @id
  notifId   String
  channel   String
  payload   Json
  createdAt DateTime @default(now())
}


// Handoff from content-service (dismemberment step 7): push-device registry
// and scheduled notification tasks belong to the Notifications extension
// service (extension layer keeps String cuid ids per the PK decision).
model DeviceToken {
  id             String    @id @default(cuid())
  userId         String
  platform       String    // ios | android | web
  token          String    @unique
  enabled        Boolean   @default(true)
  lastSeenAt     DateTime  @default(now())
  lastNotifiedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  @@index([userId])
}

model NotificationTask {
  id        String   @id @default(cuid())
  userId    String
  planId    String?
  type      String   // MEAL_REMINDER | WATER_REMINDER | SURVEY_INVITE | ...
  dueAt     DateTime
  payload   Json?
  status    String   @default("PENDING") // PENDING | SENT | CANCELLED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([status, dueAt])
  @@index([userId])
}


// Handoff from inbox-service (extension-layer consolidation): the in-app
// notification inbox belongs to the Notifications extension service.
model NotificationInbox {
  id        Int       @id @default(autoincrement())
  userId    Int
  type      String
  payload   Json
  deeplink  String?
  readAt    DateTime?
  createdAt DateTime  @default(now())
  @@index([userId, createdAt], map: "idx_inbox_user_created")
  @@index([userId, readAt], map: "idx_inbox_user_read")
}
