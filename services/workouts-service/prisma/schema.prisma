generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model WorkoutPlan {
  id          Int        @id @default(autoincrement())
  name        String
  description String?
  userId      Int?
  createdAt   DateTime   @default(now())
  exercises   Exercise[]
  workouts    Workout[]
}

model Exercise {
  id        Int         @id @default(autoincrement())
  planId    Int
  plan      WorkoutPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  name      String
  sets      Int?
  reps      Int?
  weight    Float?
  rpe       Float?
  restTime  Int?
  notes     String?
  createdAt DateTime    @default(now())

  @@index([planId], map: "idx_Exercise_planId")
}

model Workout {
  id        Int          @id @default(autoincrement())
  planId    Int?
  plan      WorkoutPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)
  userId    Int
  date      DateTime     @default(now())
  sets      Int?
  reps      Int?
  weight    Float?
  rpe       Float?
  notes     String?
  mediaUrl  String?
  createdAt DateTime     @default(now())

  @@index([userId], map: "idx_Workout_userId")
}
