{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "declaration": true,
    "sourceMap": true,
    "strict": false,
    "strictNullChecks": false,
    "strictPropertyInitialization": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "@arman/*": [
        "../../packages/*/src"
      ],
      "@contracts/*": [
        "../../contracts/*/src"
      ],
      "*": [
        "../../node_modules/*",
        "./node_modules/*"
      ],
      "@prisma/client": [
        "prisma/generated/client"
      ]
    }
  },
  "include": [
    "src",
    "prisma"
  ],
  "exclude": [
    "**/*.e2e-spec.ts",
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/__tests__/**",
    "dist",
    "node_modules",
    "test/**"
  ]
}
