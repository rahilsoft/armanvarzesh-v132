{
  "name": "@arman/backend",
  "version": "0.1.0",
  "main": "dist/app/backend/src/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node dist/app/backend/src/main.js",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "test": "jest src test/unit",
    "clean": "rimraf dist || rm -rf dist",
    "start:prod": "node dist/app/backend/src/main.js",
    "lint": "eslint .",
    "dev": "ts-node src/index.ts || echo \"no dev\"",
    "coverage": "echo \"no coverage\"",
    "prisma:generate": "prisma generate --schema src/database/prisma/schema.prisma",
    "sbom": "npx @cyclonedx/cyclonedx-npm --ignore-npm-errors --json --output-file sbom.json",
    "test:e2e": "jest test/e2e --runInBand",
    "test:legacy": "jest test/legacy",
    "test:integration": "jest test/integration --runInBand --passWithNoTests",
    "test:all": "jest"
  },
  "dependencies": {
    "@apollo/server": "^4.13.0",
    "@nestjs/apollo": "^13.1.0",
    "@nestjs/bullmq": "^11.0.0",
    "@nestjs/cache-manager": "^3.0.0",
    "@nestjs/common": "^11.1.4",
    "@nestjs/config": "^3.2.2",
    "@nestjs/core": "^11.1.4",
    "@nestjs/graphql": "^13.1.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.4",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/throttler": "^6.0.0",
    "@nestjs/websockets": "^11.1.6",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.75.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.217.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.217.0",
    "@opentelemetry/semantic-conventions": "^1.27.0",
    "@prisma/client": "^5.22.0",
    "argon2": "^0.41.1",
    "axios": "^1.7.7",
    "bcryptjs": "^3.0.2",
    "body-parser": "^1.20.2",
    "bullmq": "^5.13.2",
    "cache-manager": "^5.7.6",
