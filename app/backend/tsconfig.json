{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": [
      "ES2022"
    ],
    "declaration": false,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "removeComments": false,
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@arman/auth-kit": [
        "../../packages/auth-kit/src/index.ts"
      ],
      "@arman/env-config": [
        "../../packages/env-config/src/index.ts"
      ],
      "@arman/graphql-dataloader": [
        "../../packages/graphql-dataloader/src/index.ts"
      ],
      "@arman/graphql-utils": [
        "../../packages/graphql-utils/src/index.ts"
      ],
      "@arman/http-client": [
        "../../packages/http-client/src/index.ts"
      ],
      "@arman/infra": [
        "../../packages/infra/src/index.ts"
      ],
      "@arman/integration": [
        "../../packages/integration/src/index.ts"
      ],
      "@arman/observability": [
        "../../packages/observability/src/index.ts"
      ],
      "@arman/security-middleware": [
        "../../packages/security-middleware/src/index.ts"
      ],
      "@contracts/notifications": [
        "../../contracts/notifications/src/index.ts"
      ],
      "@contracts/nutrition": [
        "../../contracts/nutrition/src/index.ts"
      ],
      "@arman/observability-sdk/register": [
        "../../packages/observability-sdk/src/register.ts"
      ],
      "@arman/*": [
        "../../packages/*/src"
      ],
      "@contracts/*": [
        "../../contracts/*/src"
      ],
      "coach-pwa/*": [
        "app/coach-pwa/*"
      ],
      "@coach-pwa/*": [
        "app/coach-pwa/*"
      ],
      "user-app/*": [
        "app/user-app/*"
      ],
      "@user-app/*": [
        "app/user-app/*"
      ],
      "coach-app/*": [
        "app/coach-app/*"
      ],
      "@coach-app/*": [
        "app/coach-app/*"
      ],
      "media-worker/*": [
        "app/media-worker/*"
      ],
      "@media-worker/*": [
        "app/media-worker/*"
      ],
      "social-subgraph/*": [
        "app/social-subgraph/*"
      ],
      "@social-subgraph/*": [
        "app/social-subgraph/*"
      ],
      "backend/*": [
        "app/backend/*"
      ],
      "@backend/*": [
        "app/backend/*"
      ],
      "live-subgraph/*": [
        "app/live-subgraph/*"
      ],
      "@live-subgraph/*": [
        "app/live-subgraph/*"
      ],
      "admin/*": [
        "app/admin/*"
      ],
      "@admin/*": [
        "app/admin/*"
      ],
      "site/*": [
        "app/site/*"
      ],
      "@site/*": [
        "app/site/*"
      ],
      "user-pwa/*": [
        "app/user-pwa/*"
      ],
      "@user-pwa/*": [
        "app/user-pwa/*"
      ]
    },
    "skipLibCheck": true,
    "noImplicitThis": true,
    "strictPropertyInitialization": false,
    "useUnknownInCatchVariables": false,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "src/e2e/**",
    "src/otel/**",
    "src/live-session/**"
  ],
  "extends": "../../tsconfig.base.json"
}
